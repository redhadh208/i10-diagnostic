{
  "expo": {
    "name": "i10-project",
    "slug": "i10-project",
    "version": "1.0.0",
    "android": {
      "package": "com.votre_nom.i10project",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      ["react-native-bluetooth-classic", { "bluetoothConfig": { "isPeripheral": false } }]
    ]
  }
}
